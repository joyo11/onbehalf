{
  "manifest_version": 3,
  "name": "Onbehalf",
  "version": "0.1.0",
  "description": "Fills Greenhouse job applications in your own browser. You watch every keystroke. You hit Submit.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://onbehalfai.vercel.app/*",
    "https://*.greenhouse.io/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Onbehalf",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*"
      ],
      "js": [
        "src/fill/dom-surface.js",
        "src/fill/greenhouse.js",
        "src/fill/computer-use.js",
        "src/fill/walker.js",
        "src/fill/auto-fill.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
